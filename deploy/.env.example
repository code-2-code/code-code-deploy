# deploy/.env — copy this file to deploy/.env to override Makefile defaults.
# Lines are sourced by `make` via `include`. Keep values shell-safe (no spaces around =).

# --- Image build & push ---

# Registry prefix prepended to every image tag. Trailing slash is optional.
# Examples:
#   192.168.0.126:30500/      # in-cluster registry from `make registry-up`
#   ghcr.io/your-org/         # GitHub Container Registry
IMAGE_REGISTRY=

# Image tag used by `bake` and injected into helm via global.imageTag.
# Defaults to `dev-local`. CI typically sets this to a short git SHA.
IMAGE_TAG=dev-local

# Optional package mirrors (used as buildx build args).
BUILD_NPM_REGISTRY=
BUILD_GOPROXY=
BUILD_PIP_INDEX_URL=
BUILD_DEBIAN_MIRROR=

# Optional base image overrides for local/remote builders. Keep domestic mirror
# choices in deploy/.env or shell environment, not committed values.
GO_BASE_IMAGE=golang:1.26-bookworm
NODE_BASE_IMAGE=node:24-bookworm
NODE_SLIM_BASE_IMAGE=node:24-bookworm-slim
NGINX_UNPRIVILEGED_BASE_IMAGE=nginxinc/nginx-unprivileged:1.29-alpine

# Agent CLI versions used by release Dockerfiles. Defaults track the latest
# stable npm versions validated for this deployment baseline.
CLAUDE_CODE_CLI_VERSION=2.1.121
QWEN_CLI_VERSION=0.15.4
GEMINI_CLI_VERSION=0.39.1

# ARC runner tool-cache image. Build and push with:
#   IMAGE_REGISTRY=192.168.0.126:30500/ make -C deploy runner-image-push
ACTIONS_RUNNER_VERSION=2.333.1
ACTIONS_RUNNER_BASE_IMAGE=ghcr.io/actions/actions-runner:2.333.1
ACTIONS_RUNNER_GO_VERSION=1.26.2
ACTIONS_RUNNER_GO_DOWNLOAD_BASE_URL=https://go.dev/dl
ACTIONS_RUNNER_GO_DOWNLOAD_FALLBACK_BASE_URL=
ACTIONS_RUNNER_HELM_VERSION=3.20.0
ACTIONS_RUNNER_HELM_DOWNLOAD_BASE_URL=https://get.helm.sh
ACTIONS_RUNNER_HELM_DOWNLOAD_FALLBACK_BASE_URL=
ACTIONS_RUNNER_APT_MIRROR=
ACTIONS_RUNNER_APT_DISABLE_THIRD_PARTY=false
ACTIONS_RUNNER_IMAGE_TAG=runner-go1.26.2-actions-2.333.1

# --- Helm deployment ---

# Release name and namespace for `make deploy`.
RELEASE=code-code-platform
NAMESPACE=code-code

# Path to the values overlay applied on top of chart defaults.
VALUES=charts/platform/examples/local.yaml

# helm upgrade --timeout. Default 5m.
TIMEOUT=5m

# --- Ingress smoke test (`make smoke-ingress`) ---

CONSOLE_ROUTE_NAMESPACE=code-code-console
SHOWCASE_ROUTE_NAMESPACE=code-code-showcase
OBSERVABILITY_ROUTE_NAMESPACE=code-code-observability
PLATFORM_GATEWAY_NAMESPACE=code-code-net
PLATFORM_GATEWAY_NAME=platform-ingress

CONSOLE_URL=http://console.192.168.0.126.nip.io:30599/
SHOWCASE_URL=http://showcase.192.168.0.126.nip.io:30599/
GRAFANA_URL=http://grafana.192.168.0.126.nip.io:30599/login
KIALI_URL=http://kiali.192.168.0.126.nip.io:30599/
KIALI_BASE_URL=http://kiali.192.168.0.126.nip.io:30599
ANALYZE_NAMESPACES=code-code code-code-net code-code-console code-code-showcase code-code-observability

# --- Self-hosted registry chart (`make registry-up`) ---

REGISTRY_RELEASE=code-code-registry
REGISTRY_NAMESPACE=code-code-infra
REGISTRY_HELM_ARGS=
REGISTRY_CACHE_PROXY_SECRET=code-code-registry-cache-proxy
REGISTRY_CACHE_HTTP_PROXY=
REGISTRY_CACHE_HTTPS_PROXY=
REGISTRY_CACHE_NO_PROXY=

# --- GitHub Actions runners (`make arc-up`) ---

ARC_CHART_VERSION=0.14.1
ARC_CONTROLLER_RELEASE=arc
ARC_CONTROLLER_NAMESPACE=arc-systems
ARC_RUNNER_RELEASE=code-code-k8s
ARC_RUNNER_NAMESPACE=arc-runners
ARC_GITHUB_CONFIG_URL=https://github.com/code-2-code
ARC_GITHUB_AUTH_SECRET=github-arc-auth
ARC_RUNNER_IMAGE=
ARC_RUNNER_MIRRORS_CONFIGMAP=code-code-runner-mirrors
RUNNER_GOPROXY=
RUNNER_GOSUMDB=
RUNNER_GOPRIVATE=
RUNNER_NPM_REGISTRY=
RUNNER_PIP_INDEX_URL=
RUNNER_UV_INDEX_URL=

# Optional deploy-local Helm args for cluster-specific infrastructure settings.
# Keep secrets in Kubernetes Secrets, not in this file.
ARC_CONTROLLER_HELM_ARGS=
ARC_RUNNER_HELM_ARGS=

# --- Isolated infra k3d cluster (`make infra-k3d-up`) ---

# This uses k3d to run a separate K3s control plane in Docker without root.
# It is suitable for single-host infra isolation from the business k3s API.
INFRA_K3D_CLUSTER=code-code-infra
INFRA_K3D_K3S_IMAGE=rancher/k3s:v1.35.3-k3s1
INFRA_K3D_TOOLS_IMAGE=
INFRA_K3D_LOADBALANCER_IMAGE=
INFRA_K3D_API_HOST=
INFRA_K3D_API_PORT=7443
INFRA_K3D_HTTP_PORT=28080
INFRA_K3D_HTTPS_PORT=28443
INFRA_K3D_REGISTRY_CREATE=false
INFRA_K3D_REGISTRY_NAME=code-code-infra-registry
INFRA_K3D_REGISTRY_PORT=25000
INFRA_K3D_REGISTRY_CONFIG=
INFRA_K3D_SERVER_MEMORY=16g
INFRA_K3D_TIMEOUT=5m
INFRA_K3D_KUBECONFIG=
INFRA_K3D_CONFIRM_DELETE=
